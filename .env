# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=
VITE_PING_MESSAGE="Görüntüleme Sistemi Çalışıyor"

# Veritabanı Konfigürasyonu (Açık Kaynak/Ücretsiz)
# Bu proje varsayılan olarak API anahtarı GEREKTİRMEZ.
# Tüm veriler USGS, NOAA ve Open-Meteo gibi açık kaynaklardan çekilir.

# Tarama Konfigürasyonu
VITE_DEFAULT_SCAN_DEPTH=100
VITE_DEFAULT_SCAN_AREA=1000

# PayTR Ödeme Gateway Konfigürasyonu
# https://www.paytr.com/ - Türkiye'nin önde gelen ödeme gateway'i
PAYTTR_MERCHANT_ID=
PAYTTR_MERCHANT_KEY=
PAYTTR_MERCHANT_SALT=

# API Konfigürasyonu
VITE_API_URL=http://localhost:8080
NODE_ENV=development

# ============================================
# FIREBASE KONFIGÜRASYONU
# ============================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin SDK Key (Server tarafı)
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni Özel Anahtar Oluştur
# İndirilen JSON dosyasının tamamını burada JSON string olarak yapıştır
# FIREBASE_ADMIN_KEY={}
