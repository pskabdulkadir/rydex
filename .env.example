# Builder.io Fusion Starter - Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri güncelleyin

# ============================================
# BUILDER.IO
# ============================================
# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=your_builder_public_key_here

# ============================================
# UYGULAMA AYARLARI
# ============================================
PING_MESSAGE="Görüntüleme Sistemi Çalışıyor"
NODE_ENV=development
API_URL=http://localhost:8080

# ============================================
# TARAMA KONFIGÜRASYONU
# ============================================
DEFAULT_SCAN_DEPTH=100
DEFAULT_SCAN_AREA=1000

# ============================================
# ÖDEME GATEWAY (PayTR) - OPSİYONEL
# ============================================
# https://www.paytr.com
# Hesap oluşturarak kendi kimlik bilgilerinizi alın
PAYTTR_MERCHANT_ID=your_merchant_id
PAYTTR_MERCHANT_KEY=your_merchant_key
PAYTTR_MERCHANT_SALT=your_merchant_salt

# ============================================
# VERİTABANI (OPSİYONEL - PRODUCTION)
# ============================================
# Supabase Bağlantısı
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Neon Database Bağlantısı
# DATABASE_URL=postgresql://user:password@host/dbname

# ============================================
# AÇIK KAYNAK KAYNAKLAR (KONFİGÜRASYON GEREKMİYOR)
# ============================================
# Bu proje aşağıdaki açık kaynak API'lerini kullanır:
#
# - Uydu Görüntüleri: USGS, Esri, Copernicus (XYZ Tiles)
# - İklim Verisi: Open-Meteo (Ücretsiz, rate limit yok)
# - Rüzgar Verisi: Open-Meteo
# - Manyetik Alan: NOAA World Magnetic Model
# - Jeoloji/Archaeology: Overpass API, UNESCO, Open Context
# - Toprak Verisi: SoilGrids
# - Sismik Aktivite: USGS Earthquake Hazards
#
# Dokümantasyon: Bkz. .env.example (AÇIK KAYNAK API DOKÜMANTASYONU bölümü)
